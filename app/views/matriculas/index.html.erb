<% content_for :title, "Matrículas" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Matrículas</h1>
  <%= link_to "Nova Matrícula", new_matricula_path, class: "btn btn-primary" %>
</div>

<table class="table table-striped table-hover">
  <thead class="table-dark">
    <tr>
      <th>Aluno</th>
      <th>Disciplina</th>
      <th>Semestre</th>
      <th>Nota</th>
      <th>Ações</th>
    </tr>
  </thead>
  <tbody>
    <% @matriculas.each do |matricula| %>
      <tr>
        <td><%= matricula.aluno.nome %></td>
        <td><%= matricula.disciplina.nome %></td>
        <td><%= matricula.semestre %></td>
        <td><%= matricula.nota %></td>
        <td>
          <%= link_to "Ver", matricula, class: "btn btn-sm btn-info" %>
          <%= link_to "Editar", edit_matricula_path(matricula), class: "btn btn-sm btn-warning" %>
          <%= link_to "Excluir", matricula, data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" }, class: "btn btn-sm btn-danger" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<div class="d-flex justify-content-center mt-4">
  <%= paginate @matriculas %>
</div>