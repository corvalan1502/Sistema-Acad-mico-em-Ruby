<div class="row justify-content-center mt-5">
  <div class="col-md-4">
    <div class="card shadow">
      <div class="card-header bg-dark text-white text-center">
        <h4 class="mb-0">Criar Conta</h4>
      </div>
      <div class="card-body p-4">
        <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>

          <div class="mb-3">
            <%= f.label :email, "Email", class: "form-label" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control", placeholder: "Digite seu email" %>
          </div>

          <div class="mb-3">
            <%= f.label :password, "Senha", class: "form-label" %>
            <% if @minimum_password_length %>
              <small class="text-muted">(mínimo <%= @minimum_password_length %> caracteres)</small>
            <% end %>
            <%= f.password_field :password, autocomplete: "new-password", class: "form-control", placeholder: "Digite sua senha" %>
          </div>

          <div class="mb-3">
            <%= f.label :password_confirmation, "Confirmar Senha", class: "form-label" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control", placeholder: "Confirme sua senha" %>
          </div>

          <div class="d-grid">
            <%= f.submit "Criar Conta", class: "btn btn-dark btn-block" %>
          </div>
        <% end %>
      </div>
      <div class="card-footer text-center">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>