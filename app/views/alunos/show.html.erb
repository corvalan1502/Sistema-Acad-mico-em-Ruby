<% content_for :title, "Detalhes do Aluno" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Detalhes do Aluno</h1>
  <%= link_to "Voltar", alunos_path, class: "btn btn-secondary" %>
</div>

<div class="card">
  <div class="card-body">
    <div class="mb-3">
      <strong>Nome:</strong>
      <%= @aluno.nome %>
    </div>
    <div class="mb-3">
      <strong>CPF:</strong>
      <%= @aluno.cpf %>
    </div>
    <div class="mb-3">
      <strong>Data de Nascimento:</strong>
      <%= @aluno.data_nascimento&.strftime("%d/%m/%Y") %>
    </div>
  </div>
  <div class="card-footer d-flex gap-2">
    <%= link_to "Editar", edit_aluno_path(@aluno), class: "btn btn-warning" %>
    <%= link_to "Excluir", @aluno, data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" }, class: "btn btn-danger" %>
  </div>
</div>