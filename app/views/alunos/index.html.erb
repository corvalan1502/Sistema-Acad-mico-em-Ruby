<% content_for :title, "Alunos" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Alunos</h1>
  <div class="d-flex gap-2">
    <%= link_to "Exportar PDF", export_pdf_alunos_path(format: :pdf), class: "btn btn-danger" %>
    <%= link_to "Exportar CSV", export_csv_alunos_path(format: :csv), class: "btn btn-success" %>
    <%= link_to "Novo Aluno", new_aluno_path, class: "btn btn-primary" %>
  </div>
</div>

<table class="table table-striped table-hover">
  <thead class="table-dark">
    <tr>
      <th>Nome</th>
      <th>CPF</th>
      <th>Data de Nascimento</th>
      <th>Ações</th>
    </tr>
  </thead>
  <tbody>
    <% @alunos.each do |aluno| %>
      <tr>
        <td><%= aluno.nome %></td>
        <td><%= aluno.cpf %></td>
        <td><%= aluno.data_nascimento&.strftime("%d/%m/%Y") %></td>
        <td>
          <%= link_to "Ver", aluno, class: "btn btn-sm btn-info" %>
          <%= link_to "Editar", edit_aluno_path(aluno), class: "btn btn-sm btn-warning" %>
          <%= link_to "Excluir", aluno, data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" }, class: "btn btn-sm btn-danger" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<div class="d-flex justify-content-center mt-4">
  <%= paginate @alunos %>
</div>